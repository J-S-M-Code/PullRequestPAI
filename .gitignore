# 1. Ignorar todo por defecto en el repositorio.
*

# 2. Crear excepciones. NO ignorar el propio .gitignore.
!.gitignore

# 3. NO ignorar la estructura de directorios que lleva a tus clases de producción.
#    REEMPLAZA 'tu/paquete/aqui/' CON TU RUTA REAL.
!/src/
!/src/main/
!/src/main/java/
!/src/main/java/Exceptions/
!/src/main/java/model/

# 4. NO ignorar la estructura de directorios que lleva a tus clases de test.
#    REEMPLAZA 'tu/paquete/aqui/' CON TU RUTA REAL.
!/src/test/
!/src/test/java/
!/src/test/java/model/

# 5. Finalmente, NO ignorar los archivos específicos que quieres subir.
#    Asegúrate de que la ruta coincida con la de arriba.
!/src/main/java/model/Person.java
!/src/main/java/Exceptions/ExceptionsPerson.java
!/src/test/java/model/TestPerson.java